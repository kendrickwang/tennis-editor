{
  "name": "tennis-editor",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://kendrickwang.github.io/tennis-editor",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tauri-apps/api": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "npm run copy-ffmpeg && react-scripts start",
    "build": "npm run copy-ffmpeg && react-scripts build",
    "copy-ffmpeg": "node -e \"const fs=require('fs');fs.mkdirSync('public/ffmpeg',{recursive:true});fs.copyFileSync('node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.js','public/ffmpeg/ffmpeg-core.js');fs.copyFileSync('node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.wasm','public/ffmpeg/ffmpeg-core.wasm');\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "patch-package"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "gh-pages": "^6.3.0",
    "patch-package": "^8.0.1"
  }
}
